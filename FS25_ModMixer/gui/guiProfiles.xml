<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!-- ModMixer Switchboard GUI profiles. Own ModMixer_* names so they never
     collide with another mod's profiles (profile names are global). All extend
     base FS25 profiles used by stock menu frames. -->
<GUIProfiles>
    <Profile name="ModMixer_table" extends="emptyPanel" with="anchorStretchingYLeft pivotTopLeft" />

    <Profile name="ModMixer_listItem" extends="baseReference" with="anchorTopStretchingX alternating">
        <height value="40px"/>
        <imageColor value="$preset_fs25_colorGrey" />
        <imageSelectedColor value="$preset_fs25_colorMainHighlight" />
        <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50" />
    </Profile>

    <Profile name="ModMixer_cellLeft" extends="baseReference" with="anchorStretchingYLeft">
        <textBold value="false" />
        <textSize value="16px" />
        <textAlignment value="left" />
        <textColor value="$preset_fs25_colorMainLight" />
        <textSelectedColor value="$preset_fs25_colorMainDark" />
        <textDisabledColor value="$preset_colorDisabled" />
    </Profile>

    <Profile name="ModMixer_cellState" extends="ModMixer_cellLeft">
        <textBold value="true" />
    </Profile>

    <Profile name="ModMixer_colHeader" extends="baseReference" with="anchorTopLeft">
        <textSize value="15px" />
        <textBold value="true" />
        <textUpperCase value="true" />
        <textAlignment value="left" />
        <textColor value="$preset_colorWhite_50" />
    </Profile>

    <!-- Clickable column header (Performance-tier sort). Transparent button background
         (imageColor alpha 0) so it reads as a header, not a box; same text as ModMixer_colHeader,
         tinted green on hover/focus. The TSSC recipe. -->
    <Profile name="ModMixer_colHeaderBtn" extends="baseReference" with="anchorTopLeft">
        <imageColor value="0 0 0 0" />
        <textSize value="15px" />
        <textBold value="true" />
        <textUpperCase value="true" />
        <textAlignment value="left" />
        <textColor value="$preset_colorWhite_50" />
        <textHighlightedColor value="$preset_fs25_colorMainHighlight" />
        <textFocusedColor value="$preset_fs25_colorMainHighlight" />
        <textDisabledColor value="$preset_colorDisabled" />
    </Profile>

    <Profile name="ModMixer_headerInfo" extends="fs25_statisticsHeaderText" with="anchorTopLeft">
        <textMaxNumLines value="2"/>
        <textVerticalAlignment value="top"/>
        <textAlignment value="left"/>
    </Profile>

    <!-- Feature help box (top-right): plain-English explanation of the selected row.
         Multi-line, top-aligned, a touch brighter than the bottom legend. -->
    <Profile name="ModMixer_helpBox" extends="fs25_statisticsHeaderText" with="anchorTopLeft">
        <textMaxNumLines value="8"/>
        <textVerticalAlignment value="top"/>
        <textSize value="15px"/>
        <textAlignment value="left"/>
        <textColor value="$preset_fs25_colorMainLight"/>
    </Profile>

    <Profile name="ModMixer_sliderBox" extends="fs25_listSliderBox" with="anchorTopRight" />

    <!-- Category filter: a stock left/right text switcher (same widget RedTape
         uses for its scheme display switcher). -->
    <Profile name="ModMixer_categoryFilter" extends="fs25_subCategorySelector" with="anchorTopLeft" />

    <!-- Value slider: compact MultiTextOption — 190px keeps arrows tight around
         the number. anchorStretchingYLeft centres vertically in 40px list item. -->
    <Profile name="ModMixer_valueSlider" extends="fs25_subCategorySelector" with="anchorStretchingYLeft" />

    <!-- Value fill bar: stock contracts progress-bar widget (real engine textures,
         no font glyphs / no white-quad guessing). Track = stock grey background;
         fill = green, its width set at runtime in populateCellForItemInSection via
         the RedTape setSize recipe. Fill is nested inside the track in the ListItem
         so it grows from the track's left edge. -->
    <Profile name="ModMixer_scaleTrack" extends="fs25_contractsProgressBarBg" with="anchorTopLeft" />
    <Profile name="ModMixer_scaleFill" extends="fs25_contractsProgressBar">
        <imageColor value="0.35 0.85 0.25 1" />
    </Profile>

    <!-- VIEW tabs: the stock tabbed-selector look (same widgets RedTape uses for policies/
         schemes/tax). Extending fs25_subCategorySelectorTabbedTab inherits white-on-dark
         inactive + green-fill/black-text selected; we only nudge the font up a touch and pin
         anchorTopLeft for our explicit positions. The green FILL comes from the nested
         fs25_subCategorySelectorTabbedTabBg "background" bitmap (SwitchboardFrame.xml), driven
         by a getIsSelected override on that child in onGuiSetupFinished. -->
    <Profile name="ModMixer_tab" extends="fs25_subCategorySelectorTabbedTab" with="anchorTopLeft">
        <textSize value="14px" />
    </Profile>

    <!-- Tabs are coloured by LEVEL so the user knows at a glance what they're working at:
           amber = conflict resolution, applied at boot (changes need a RESTART)
           green = live runtime tuning / observation (instant, no restart)
           grey  = advisory info (Review)
         Idle text takes the group colour; the selected tab still uses the stock green-fill /
         black-text highlight (the "you are here"), and the coloured group labels above each
         cluster carry the level even on the selected tab. -->
    <Profile name="ModMixer_tab_restart" extends="ModMixer_tab">
        <textColor value="0.95 0.66 0.18 1" />
    </Profile>
    <Profile name="ModMixer_tab_live" extends="ModMixer_tab">
        <textColor value="0.40 0.85 0.28 1" />
    </Profile>
    <Profile name="ModMixer_tab_info" extends="ModMixer_tab">
        <textColor value="0.72 0.72 0.68 1" />
    </Profile>

    <!-- Group header labels in the empty band between the title and the tab row. Sentence-case
         (matches the approved mockup), bold, small, coloured to match each cluster's tabs. -->
    <Profile name="ModMixer_groupLabel" extends="ModMixer_colHeader">
        <textSize value="13px" />
        <textUpperCase value="false" />
    </Profile>
    <Profile name="ModMixer_groupLabelRestart" extends="ModMixer_groupLabel">
        <textColor value="0.95 0.66 0.18 1" />
    </Profile>
    <Profile name="ModMixer_groupLabelLive" extends="ModMixer_groupLabel">
        <textColor value="0.40 0.85 0.28 1" />
    </Profile>
    <Profile name="ModMixer_groupLabelInfo" extends="ModMixer_groupLabel">
        <textColor value="0.72 0.72 0.68 1" />
    </Profile>

    <!-- Header badge icon: our faders glyph as an atlas slice (modMixer.icon_faders,
         from gui/ui_elements.xml). Extends the stock header-icon profile so it inherits
         the badge size; only the slice + tint change. WHY THE SLICE ROUTE: the stock
         fs25_menuHeaderIcon carries its own atlas slice/UVs, so a runtime setImageFilename
         swaps the file but keeps the old UVs → samples an empty region → blank green badge.
         Pointing imageSliceId at our own registered slice is how NWT/TerraFarm do it. -->
    <Profile name="ModMixer_menuHeaderIcon" extends="fs25_menuHeaderIcon">
        <imageSliceId value="modMixer.icon_faders" />
        <imageColor value="1 1 1 1" />
    </Profile>
</GUIProfiles>
