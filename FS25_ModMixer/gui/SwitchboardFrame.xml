<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!-- ModMixer Switchboard in-game-menu page. Layout modelled on stock menu frames
     (fs25_menuContainer / fs25_menuHeaderPanel) + a SmoothList of mod-feature rows.
     Element ids auto-bind to self.<id> on the frame (categoryHeaderText, featureList). -->
<GUI name="ModMixerSwitchboard">
    <GuiElement profile="fs25_menuContainer">

        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="ModMixer_menuHeaderIcon" id="categoryHeaderIcon"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" id="categoryHeaderText"/>
        </GuiElement>

        <!-- VIEW tabs (stock RedTape recipe): fs25_subCategorySelectorTabbedTab buttons, each
             with a nested "background" bitmap (fs25_subCategorySelectorTabbedTabBg). Inactive =
             white text, transparent fill; selected = green fill + black text. The frame overrides
             getIsSelected on BOTH the button (text) and its background (fill) in
             onGuiSetupFinished so they follow the live mode. Kept left of the help box (x<580). -->
        <Button profile="ModMixer_tab" id="tab1" text="Simple"      position="20px -58px"  size="72px 40px"  onClick="onTab1">
            <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
        </Button>
        <Button profile="ModMixer_tab" id="tab2" text="Live"        position="105px -58px" size="56px 40px"  onClick="onTab2">
            <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
        </Button>
        <Button profile="ModMixer_tab" id="tab3" text="Category"    position="174px -58px" size="90px 40px"  onClick="onTab3">
            <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
        </Button>
        <Button profile="ModMixer_tab" id="tab4" text="Advanced"    position="277px -58px" size="90px 40px"  onClick="onTab4">
            <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
        </Button>
        <Button profile="ModMixer_tab" id="tab5" text="Review"      position="380px -58px" size="72px 40px"  onClick="onTab5">
            <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
        </Button>
        <Button profile="ModMixer_tab" id="tab6" text="Performance" position="465px -58px" size="122px 40px" onClick="onTab6">
            <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
        </Button>
        <Button profile="ModMixer_tab" id="tab7" text="Vehicle"     position="600px -58px" size="78px 40px"  onClick="onTab7">
            <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
        </Button>

        <!-- Category pager (Tier 2 only): page with the menu's prev/next or the arrows. -->
        <MultiTextOption profile="ModMixer_categoryFilter" id="categoryFilter"
                         position="20px -120px" size="520px 34px" onClick="onFilterChanged"/>

        <!-- Feature help box — lifted up into the empty top-right band (right of the title,
             above the tab row; +Y = up in this frame). Clear of the title (ends ~610px) and the
             tabs (end ~578px). Updated on row selection. -->
        <Text profile="ModMixer_helpBox" id="featureHelp" text=""
              position="690px 66px" size="820px 215px"/>

        <!-- Tier legend / description — sits between the category filter and the column headers,
             with breathing room above and below. Text is set per-tier from Lua. -->
        <Text profile="ModMixer_headerInfo" id="headerInfo" text=""
              position="20px -168px" size="1480px 36px"/>

        <!-- MOD + FEATURE headers are clickable in the Performance tier to sort the per-mod cost
             list (by name / by cost). Stock sort-arrow bitmaps are revealed on the active column
             by updateChrome and hidden in every other tier. STATE stays a plain label. -->
        <Button profile="ModMixer_colHeaderBtn" id="colMod" text="MOD" position="20px -216px" size="500px 24px" onClick="onSortByName">
            <Bitmap profile="fs25_vehiclesHeaderIconSortAscending"  id="sortModAsc"  position="58px 0px"/>
            <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" id="sortModDesc" position="58px 0px"/>
        </Button>
        <Button profile="ModMixer_colHeaderBtn" id="colFeat" text="FEATURE" position="530px -216px" size="440px 24px" onClick="onSortByCost">
            <Bitmap profile="fs25_vehiclesHeaderIconSortAscending"  id="sortFeatAsc"  position="98px 0px"/>
            <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" id="sortFeatDesc" position="98px 0px"/>
        </Button>
        <Text profile="ModMixer_colHeader" text="STATE"   position="1000px -216px" size="300px 24px"/>
        <ThreePartBitmap profile="fs25_lineSeparatorTopHighlighted" position="0px -244px"/>

        <SmoothList id="featureList" profile="ModMixer_table" position="20px -252px" size="1480px 474px">
            <ListItem profile="ModMixer_listItem">
                <Text profile="ModMixer_cellLeft"  position="20px 0px"   size="500px 40px" name="mod"/>
                <Text profile="ModMixer_cellLeft"  position="530px 0px"  size="440px 40px" name="feature"/>
                <!-- State text: toggle / hook rows -->
                <Text profile="ModMixer_cellState" position="1000px 0px" size="480px 40px" name="state"/>
                <!-- Value rows: smooth green fill bar (stock contracts progress-bar
                     widget — real engine textures; fill nested in track, its width
                     driven per-row in populateCell) + compact MTO slider. -->
                <ThreePartBitmap profile="ModMixer_scaleTrack" position="1000px -13px" size="240px 14px" name="valueScaleTrack">
                    <ThreePartBitmap profile="ModMixer_scaleFill" name="valueScaleFill"/>
                </ThreePartBitmap>
                <MultiTextOption profile="ModMixer_valueSlider" position="1280px 3px" size="190px 34px"
                                 name="valueSlider" onClick="onValueSliderChanged"/>
            </ListItem>
        </SmoothList>

        <ThreePartBitmap profile="ModMixer_sliderBox" position="1500px -252px" size="6px 474px">
            <Slider profile="fs25_listSlider" dataElementId="featureList"/>
        </ThreePartBitmap>

    </GuiElement>
</GUI>
